{
  "name": "obsidian-graph-analysis",
  "version": "0.3.0",
  "description": "Analyze Obsidian vault using graph algorithms to provide insights into note structure and relationships",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json",
    "copy-to-vault": "node scripts/copy-to-vault.mjs",
    "build-wasm": "cd graph-analysis-wasm && wasm-pack build --target web --release",
    "full-build": "npm run build-wasm && npm run build",
    "test": "cd graph-analysis-wasm && cargo test",
    "lint": "eslint . --ext .ts --config config/.eslintrc"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "graph",
    "analysis",
    "centrality"
  ],
  "author": "wluo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wluo/obsidian-graph-analysis"
  },
  "bugs": {
    "url": "https://github.com/wluo/obsidian-graph-analysis/issues"
  },
  "homepage": "https://github.com/wluo/obsidian-graph-analysis#readme",
  "devDependencies": {
    "@types/chroma-js": "^3.1.1",
    "@types/d3-array": "^3.2.1",
    "@types/d3-color": "^3.1.3",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/node": "^16.18.126",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.2.0",
    "builtin-modules": "^3.2.0",
    "esbuild": "^0.25.4",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "chroma-js": "^3.1.2",
    "d3": "^7.9.0",
    "d3-array": "^3.2.4",
    "d3-color": "^3.1.0",
    "d3-scale-chromatic": "^3.1.0",
    "simple-statistics": "^7.8.8"
  }
}
